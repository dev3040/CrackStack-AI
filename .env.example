# Free tier (recommended): https://console.groq.com → API keys
GROQ_API_KEY=

# Optional: OpenRouter free models — https://openrouter.ai (use a :free model via LLM_MODEL)
# OPENROUTER_API_KEY=
# OPENROUTER_HTTP_REFERER=http://localhost
# LLM_MODEL=meta-llama/llama-3.2-3b-instruct:free

# Optional paid fallback
# OPENAI_API_KEY=

# Override model for the active provider (Groq default: llama-3.1-8b-instant)
# LLM_MODEL=

# Max output tokens for the plain-text code step (second API call). Defaults to LLM_MAX_TOKENS or 8192.
# LLM_MAX_TOKENS=8000
# LLM_CODE_MAX_TOKENS=8000

# Max tokens for bottom “Chat with AI” (default 3072)
# LLM_CHAT_MAX_TOKENS=4096

# Speech-to-text (optional)
# DEEPGRAM_API_KEY=

# Hide overlay from screen capture (default on). Set false to debug / allow capture.
# CONTENT_PROTECTION=false

# Show app icon in Windows taskbar (default: hidden). Uncomment to pin to taskbar while debugging.
# SHOW_IN_TASKBAR=true
