# Free tier (recommended): https://console.groq.com → API keys
GROQ_API_KEY=

# Optional: OpenRouter free models — https://openrouter.ai (use a :free model via LLM_MODEL)
# OPENROUTER_API_KEY=
# OPENROUTER_HTTP_REFERER=http://localhost
# LLM_MODEL=meta-llama/llama-3.2-3b-instruct:free

# Optional paid fallback
# OPENAI_API_KEY=

# Override model for the active provider (Groq default: llama-3.1-8b-instant)
# LLM_MODEL=

# Max output tokens (structured + code step). Groq free/on-demand TPM is often 6000 — use ~4096 or lower, or set GROQ_MAX_OUTPUT_TOKENS.
# LLM_MAX_TOKENS=4096
# LLM_CODE_MAX_TOKENS=4096
# GROQ_MAX_OUTPUT_TOKENS=3584

# Max tokens for bottom “Chat with AI” (default 3072)
# LLM_CHAT_MAX_TOKENS=4096

# Speech-to-text (optional)
# DEEPGRAM_API_KEY=
#
# Accuracy / meeting tuning (optional):
# DEEPGRAM_MODEL=nova-3          # default; try nova-2-meeting for multi-speaker calls or if Nova-3 errors
# DEEPGRAM_LANGUAGE=en           # lock language; use multi + a multilingual model for mixed languages
# DEEPGRAM_ENDPOINTING=550       # ms silence before end-of-utterance (higher = fewer chopped words on choppy audio)
# DEEPGRAM_UTTERANCE_END_MS=1300
# DEEPGRAM_SMART_FORMAT=false    # set false if numbers/dates look wrong in transcripts
# DEEPGRAM_KEYTERMS=Kubernetes,OAuth,gRPC,LeetCode   # Nova-3: keyterm; Nova-2: keyword boost (optional :1.5)

# Hide overlay from screen capture (default on). Set false to debug / allow capture.
# CONTENT_PROTECTION=false

# Show app icon in Windows taskbar (default: hidden). Uncomment to pin to taskbar while debugging.
# SHOW_IN_TASKBAR=true
